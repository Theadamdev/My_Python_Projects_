#don't forget to install the openai library using pip install openai , and get your api key
import tkinter as tk
from tkinter.scrolledtext import ScrolledText
from openai import OpenAI

client = OpenAI(api_key="put api key here")

messages = []


def add_message(sender, text):
    chatbox.configure(state="normal")
    chatbox.insert(tk.END, f"{sender}: {text}\n\n")
    chatbox.configure(state="disabled")
    chatbox.see(tk.END)


def ask_ai(prompt):
    messages.append({"role": "user", "content": prompt})

    response = client.chat.completions.create(
        model="gpt-5",
        messages=messages
    )

    reply = response.choices[0].message.content
    messages.append({"role": "assistant", "content": reply})

    return reply


def send_message(event=None):
    user_input = message_entry.get().strip()

    if not user_input:
        return

    message_entry.delete(0, tk.END)
    add_message("You", user_input)

    try:
        reply = ask_ai(user_input)
        add_message("AI", reply)

    except Exception as error:
        add_message("Error", str(error))

window = tk.Tk()
window.title("Mini ChatGPT")
window.geometry("800x600")
window.configure(bg="#202123")

heading = tk.Label(
    window,
    text="Mini ChatGPT",
    bg="#202123",
    fg="white",
    font=("Arial", 20, "bold")
)
heading.pack(pady=10)

chatbox = ScrolledText(
    window,
    wrap="word",
    bg="#343541",
    fg="white",
    font=("Arial", 12),
    insertbackground="white"
)

chatbox.pack(fill="both", expand=True, padx=10, pady=10)
chatbox.configure(state="disabled")

bottom_frame = tk.Frame(window, bg="#202123")
bottom_frame.pack(fill="x", padx=10, pady=10)

message_entry = tk.Entry(
    bottom_frame,
    bg="#40414F",
    fg="white",
    insertbackground="white",
    font=("Arial", 12)
)

message_entry.pack(side="left", fill="x", expand=True, ipady=8)
message_entry.bind("<Return>", send_message)

send_button = tk.Button(
    bottom_frame,
    text="Send",
    command=send_message,
    bg="#10A37F",
    fg="white",
    font=("Arial", 11, "bold")
)

send_button.pack(side="right", padx=(10, 0))

window.mainloop()
